---
import BaseListing from "../../layouts/BaseListing.astro";
import { PAGES, PAGES_ZH } from "../../config";

if (PAGES.talks.isActive === false) {
    return Astro.redirect("/404");
}
---

<BaseListing
    collection="talks"
    title={PAGES.talks.title}
    subtitle={PAGES.talks.subtitle}
    titleZh={PAGES_ZH.talks?.title}
    subtitleZh={PAGES_ZH.talks?.subtitle}
/>