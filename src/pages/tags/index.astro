---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags } from "../../utils/tags";
import Tag from "../../components/ui/Tag.astro";

const tags = await getAllTags();

const maxCount = Math.max(...tags.map((t) => t.count));
const minCount = Math.min(...tags.map((t) => t.count));

function getTagSize(count: number): "sm" | "md" | "lg" {
    if (tags.length < 5) return "md";
    const range = maxCount - minCount;
    if (range === 0) return "md";

    const normalized = (count - minCount) / range;
    if (normalized > 0.7) return "lg";
    if (normalized > 0.3) return "md";
    return "sm";
}
---

<BaseLayout title="Tags">
    <header class="page-header">
        <h1 class="page-title">Tags</h1>
        <p class="page-subtitle">{tags.length} unique topics</p>
    </header>

    <div class="container-narrow pt-12">
        <div
            class="flex flex-wrap gap-4 items-center justify-center min-h-[300px] stagger-fade-in"
        >
            {
                tags.map((tag) => (
                    <Tag
                        name={tag.name}
                        count={tag.count}
                        size={getTagSize(tag.count)}
                    />
                ))
            }
        </div>

        {
            tags.length === 0 && (
                <p class="text-center text-text-muted mt-20 font-mono italic">
                    No tags found in your content yet.
                </p>
            )
        }
    </div>
</BaseLayout>