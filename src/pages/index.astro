---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { PAGES, PAGES_ZH } from "../config";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };
---

<BaseLayout title={PAGES.home.title}>
	<div class="container-narrow">
		{
			(PAGES.home.title || PAGES.home.subtitle) && (
				<header class="page-header">
					{PAGES.home.title && (
						<h1 class="page-title"><span class="lang-en">{PAGES.home.title}</span><span class="lang-zh">{PAGES_ZH.home?.title || '关于我'}</span></h1>
					)}
					{PAGES.home.subtitle && (
						<p class="page-subtitle">{PAGES.home.subtitle}</p>
					)}
				</header>
			)
		}
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Bio content not available.</p>}
		</div>
	</div>
</BaseLayout>