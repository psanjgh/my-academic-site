---
import BaseListing from "../../layouts/BaseListing.astro";
import { PAGES, PAGES_ZH } from "../../config";

if (PAGES.teaching.isActive === false) {
    return Astro.redirect("/404");
}
---

<BaseListing
    collection="teaching"
    title={PAGES.teaching.title}
    subtitle={PAGES.teaching.subtitle}
    titleZh={PAGES_ZH.teaching?.title}
    subtitleZh={PAGES_ZH.teaching?.subtitle}
/>