---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/ui/Timeline.astro";
import { PAGES, PAGES_ZH } from "../../config";

if (PAGES.cv.isActive === false) {
    return Astro.redirect("/404");
}

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error("CV content not found. Please ensure src/content/cv.md exists.");
}

const { Content } = await render(cvEntry);
const {
    name,
    title,
    experience = [],
    education = [],
    awards = [],
} = cvEntry.data;

const titleZhMap: Record<string, string> = {
    "Graduate Teaching Assistant": "研究生助教",
    "Learning Assistant": "学习助理",
    "IT Audit Summer Intern": "IT 审计暑期实习生",
    "Corporate & Financial Analyst Intern": "企业与金融分析师实习生",
    "PhD in Physics": "物理学博士",
    "Master (MSc) in Physics": "物理学硕士 (MSc)",
    "Bachelor of Science in Physics and Mathematics": "物理与数学双学士",
    "Conference Travel Support": "会议差旅资助",
    "PhD Scholarship": "博士奖学金",
    "Dean's List": "院长嘉许名单",
};

const instZhMap: Record<string, string> = {
    "University of Edinburgh": "爱丁堡大学",
    "University of Central Florida": "中佛罗里达大学",
    "Imperial College London": "帝国理工学院",
    "Deloitte (Hong Kong S.A.R.)": "德勤（香港）",
    "Tongfang Kontafarma Holdings Ltd (Hong Kong S.A.R.)": "同方康泰（香港）",
};

function tz(en: string): string { return titleZhMap[en] || en; }
function iz(en: string): string { return instZhMap[en] || en; }
---

<BaseLayout title={PAGES.cv.title}>
    <header class="page-header">
        <h1 class="page-title">
            <span class="lang-en">{PAGES.cv.title}</span>
            <span class="lang-zh">{PAGES_ZH.cv?.title || '个人简历'}</span>
        </h1>
        <p class="page-subtitle">
            <span class="lang-en">{PAGES.cv.subtitle}</span>
            <span class="lang-zh">{PAGES_ZH.cv?.subtitle || '学术背景与职业经历'}</span>
        </p>
    </header>
    <div class="container-narrow">
        <!-- English Sections -->
        <div class="lang-en">
            {experience.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">Professional & Teaching Experience</h2>
                    <Timeline items={experience.map(exp => ({
                        title: exp.role,
                        subtitle: exp.institution,
                        period: exp.period,
                        description: exp.description,
                    }))} />
                </section>
            )}
            {education.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">Education</h2>
                    <Timeline items={education.map(edu => ({
                        title: edu.degree,
                        subtitle: edu.institution,
                        period: edu.period,
                        description: edu.description,
                        thesis: edu.thesis,
                    }))} />
                </section>
            )}
            {awards.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">Funding, Scholarships & Awards</h2>
                    <Timeline items={awards.map(a => ({
                        title: a.title,
                        subtitle: a.from,
                        period: a.year,
                        description: a.detail,
                    }))} />
                </section>
            )}
        </div>
        <!-- Chinese Sections -->
        <div class="lang-zh">
            {experience.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">职业与教学经历</h2>
                    <Timeline items={experience.map(exp => ({
                        title: tz(exp.role),
                        subtitle: iz(exp.institution),
                        period: exp.period,
                        description: ((exp as any).description_zh) || exp.description,
                    }))} />
                </section>
            )}
            {education.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">教育背景</h2>
                    <Timeline items={education.map(edu => ({
                        title: tz(edu.degree),
                        subtitle: iz(edu.institution),
                        period: edu.period,
                        description: ((edu as any).description_zh) || edu.description,
                        thesis: edu.thesis,
                    }))} />
                </section>
            )}
            {awards.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">奖学金与荣誉</h2>
                    <Timeline items={awards.map(a => ({
                        title: tz(a.title),
                        subtitle: (a as any).from_zh || a.from,
                        period: a.year,
                        description: (a as any).detail_zh || a.detail,
                    }))} />
                </section>
            )}
        </div>
        <div class="prose max-w-none"><Content /></div>
    </div>
</BaseLayout>