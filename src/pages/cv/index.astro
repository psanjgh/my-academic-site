---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/ui/Timeline.astro";
import { PAGES, PAGES_ZH } from "../../config";

if (PAGES.cv.isActive === false) {
    return Astro.redirect("/404");
}

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error("CV content not found. Please ensure src/content/cv.md exists.");
}

const { Content } = await render(cvEntry);
const { name, title, experience = [], education = [] } = cvEntry.data;

const titleZhMap: Record<string, string> = {
    "Teaching Assistant": "助教",
    "PhD in Condensed Matter Physics": "凝聚态物理博士",
    "Master (MSc) in Physics": "物理学硕士 (MSc)",
    "Bachelor of Science in Physics and Mathematics": "物理与数学双学士",
};

const instZhMap: Record<string, string> = {
    "University of Edinburgh": "爱丁堡大学",
    "University of Central Florida": "中佛罗里达大学",
    "Imperial College London": "帝国理工学院",
};

function tz(en: string): string { return titleZhMap[en] || en; }
function iz(en: string): string { return instZhMap[en] || en; }
---

<BaseLayout title={PAGES.cv.title}>
    <header class="page-header">
        <h1 class="page-title">
            <span class="lang-en">{PAGES.cv.title}</span>
            <span class="lang-zh">{PAGES_ZH.cv?.title || '个人简历'}</span>
        </h1>
        <p class="page-subtitle">
            <span class="lang-en">{PAGES.cv.subtitle}</span>
            <span class="lang-zh">{PAGES_ZH.cv?.subtitle || '学术与职业经历'}</span>
        </p>
    </header>
    <div class="container-narrow">
        <div class="lang-en">
            {experience.length > 0 && (
                <section class="section"><h2 class="section-title border-b border-border pb-2">Professional Experience</h2>
                <Timeline items={experience.map(exp => ({ title: exp.role, subtitle: exp.institution, period: exp.period, description: exp.description }))} /></section>
            )}
            {education.length > 0 && (
                <section class="section"><h2 class="section-title border-b border-border pb-2">Education</h2>
                <Timeline items={education.map(edu => ({ title: edu.degree, subtitle: edu.institution, period: edu.period, description: edu.description, thesis: edu.thesis }))} /></section>
            )}
        </div>
        <div class="lang-zh">
            {experience.length > 0 && (
                <section class="section"><h2 class="section-title border-b border-border pb-2">职业经历</h2>
                <Timeline items={experience.map(exp => ({ title: tz(exp.role), subtitle: iz(exp.institution), period: exp.period, description: (exp as any).description_zh || exp.description }))} /></section>
            )}
            {education.length > 0 && (
                <section class="section"><h2 class="section-title border-b border-border pb-2">教育背景</h2>
                <Timeline items={education.map(edu => ({ title: tz(edu.degree), subtitle: iz(edu.institution), period: edu.period, description: (edu as any).description_zh || edu.description, thesis: edu.thesis }))} /></section>
            )}
        </div>
        <div class="prose max-w-none"><Content /></div>
    </div>
</BaseLayout>