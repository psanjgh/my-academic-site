---
import { SITE, THEME_CONFIG, SETTINGS } from "../../config";
import { toBaseHref } from "../../utils/url";
import Icon from "../ui/Icon.astro";

const currentYear = new Date().getFullYear();
const showToggle = THEME_CONFIG.lightAndDark;
const showRSS = SETTINGS.showRSSInFooter;
const showDevTools = import.meta.env.DEV || SETTINGS.addDevToolsInProduction;
---

<footer class="footer">
    <div class="flex items-center gap-4">
        <span class="body-xs">&copy; {currentYear} {SITE.author}.</span>
    </div>
    <div class="flex items-center gap-4">
        <span class="body-xs hidden sm:inline-block"
            >Built with <a
                href="https://github.com/rubzip/academic-portfolio-astro/"
                target="_blank"
                rel="noopener noreferrer"
                class="link">Academic Portfolio Astro</a
            ></span
        >
        <button
            id="lang-toggle"
            aria-label="语言 / Language"
            class="btn-icon"
        >
            <span class="lang-en" style="font-size:0.7rem;font-weight:700;width:20px;text-align:center">中</span>
            <span class="lang-zh" style="font-size:0.7rem;font-weight:700;width:20px;text-align:center">EN</span>
        </button>
        {
            showRSS && (
                <a
                    href={toBaseHref("/rss.xml")}
                    aria-label="RSS Feed"
                    title="RSS Feed"
                    target="_blank"
                    rel="noreferrer"
                    class="btn-icon"
                >
                    <Icon name="RSS" size={16} />
                </a>
            )
        }
        {
            showToggle && (
                <button
                    id="theme-toggle"
                    aria-label="Toggle Dark Mode"
                    class="btn-icon"
                >
                    <Icon name="Sun" size={16} class="hidden dark:block" />
                    <Icon name="Moon" size={16} class="block dark:hidden" />
                </button>
            )
        }
        {
            showDevTools && (
                <a
                    href={toBaseHref("/dev-tools")}
                    aria-label="Developer Tools"
                    title="Developer Tools"
                    class="btn-icon"
                >
                    <Icon name="Settings" size={16} />
                </a>
            )
        }
    </div>
</footer>